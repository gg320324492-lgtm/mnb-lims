.picker-box {
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 14rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
}

.device-item {
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
