/* mine.wxss */

.container {
  min-height: 100vh;
  background: #f3f4f6;
  padding: 24rpx 24rpx 40rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #0ea5e9 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(29,78,216,0.25);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 4rpx solid rgba(255,255,255,0.4);
}

.user-avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.02em;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.15);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  display: inline-block;
}

.user-role-empty {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

/* 登录/退出区域 */
.auth-section {
  margin-bottom: 24rpx;
}

.btn-wx-login {
  width: 100%;
  background: #07c160;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 26rpx 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.3);
  border: none;
  letter-spacing: 0.02em;
}

.btn-wx-login::after {
  border: none;
}

.wx-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}

.btn-logout {
  width: 100%;
  background: #fee2e2;
  color: #dc2626;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 22rpx 0;
  border: 2rpx solid #fecaca;
  letter-spacing: 0.02em;
}

.btn-logout::after {
  border: none;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.input {
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
}

.btn-primary {
  width: 100%;
  background: #2563eb;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 0;
  margin-bottom: 12rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.muted {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.6;
}

/* 记录列表 */
.record-item {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.record-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.badge.pending  { background: #fef3c7; color: #d97706; }
.badge.approved,
.badge.available,
.badge.returned { background: #d1fae5; color: #059669; }
.badge.rejected,
.badge.borrowed { background: #fee2e2; color: #dc2626; }
.badge.cancelled { background: #f3f4f6; color: #6b7280; }
