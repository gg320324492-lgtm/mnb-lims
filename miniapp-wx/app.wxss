page {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label {
  color: #6b7280;
  margin-bottom: 8rpx;
}

.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1f2937;
  background: #e5e7eb;
}

.badge.pending { background: #fef3c7; color: #92400e; }
.badge.approved { background: #dcfce7; color: #166534; }
.badge.rejected { background: #fee2e2; color: #991b1b; }
.badge.borrowed { background: #dbeafe; color: #1e40af; }
.badge.returned { background: #e0e7ff; color: #3730a3; }

.btn-primary {
  margin-top: 16rpx;
  background: #2563eb !important;
  color: #fff !important;
  border-radius: 14rpx;
}

.muted { color: #6b7280; font-size: 24rpx; }
