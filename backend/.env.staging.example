PORT=3001
NODE_ENV=staging

# e.g. https://staging-api.yourdomain.com
PUBLIC_WEB_BASE=

# comma separated origins
CORS_ORIGINS=
CORS_ALLOW_ALL=false

USE_MYSQL=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lab_miniapp
DB_POOL_SIZE=10

# JWT auth
JWT_ACCESS_SECRET=replace_with_staging_access_secret
JWT_REFRESH_SECRET=replace_with_staging_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30
AUTH_ALLOW_USER_ID_LOGIN=false
AUTH_FAIL_WINDOW_MS=600000
AUTH_FAIL_MAX=5
AUTH_FAIL_BLOCK_MS=900000
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=60000
AUTH_REFRESH_RATE_LIMIT_MAX=20
