PORT=3000
NODE_ENV=development

# CORS allowlist, comma separated. Example:
# CORS_ORIGINS=https://miniapp.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=
# only for local debug; production/staging should keep false
CORS_ALLOW_ALL=true

# Database switch
USE_MYSQL=false

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lab_miniapp
DB_POOL_SIZE=10

# JWT auth
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30

# Whether to allow legacy userId login in this environment.
# production should set false after all clients migrate to password/SSO.
AUTH_ALLOW_USER_ID_LOGIN=true

# login failure lock strategy
AUTH_FAIL_WINDOW_MS=600000
AUTH_FAIL_MAX=5
AUTH_FAIL_BLOCK_MS=900000

# refresh short-window protection
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=60000
AUTH_REFRESH_RATE_LIMIT_MAX=20
