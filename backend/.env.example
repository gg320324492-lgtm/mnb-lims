PORT=3000
NODE_ENV=development

# CORS allowlist, comma separated. Example:
# CORS_ORIGINS=https://miniapp.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=

# Database switch
USE_MYSQL=false

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lab_miniapp
DB_POOL_SIZE=10
